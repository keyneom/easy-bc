{
  "name": "easy-bc-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "cargo build -p planner-core --target wasm32-unknown-unknown --features wasm --release && wasm-bindgen ../target/wasm32-unknown-unknown/release/planner_core.wasm --out-dir pkg --target web",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.3",
    "vite": "^6.0.1",
    "vitest": "^3.0.0"
  }
}
