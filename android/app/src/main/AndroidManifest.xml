<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Calendar sync: we write the user's cycle/plan into a local EasyBC
        calendar on their device. No data leaves the phone — the user can
        optionally sync that calendar out via their device account (Google
        Calendar, Apple Calendar, etc.) but that is their choice.
    -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <application
        android:name=".EasyBCApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.EasyBCPlanner">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.EasyBCPlanner">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
